# Google OAuth 2.0 Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Google Sheet ID (from the URL: https://docs.google.com/spreadsheets/d/{THIS_PART}/edit)
GOOGLE_SHEET_ID=your-google-sheet-id

# Google Calendar ID (usually your email address, or a specific calendar ID)
GOOGLE_CALENDAR_ID=your-email@gmail.com

# Webhook secret — used to verify requests from ElevenLabs
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=change-me-to-a-random-string

# Your public domain (used by Traefik labels and OAuth redirect)
DOMAIN=webhook.yourdomain.com
APP_URL=https://webhook.yourdomain.com

# Path inside container to persist OAuth tokens
TOKEN_PATH=/data/token.json
